{
  "name": "fixup-twitter-link",
  "main": "dist/src/main.js",
  "type": "module",
  "scripts": {
    "start": "node .",
    "dev": "SWCRC=true node --import=@swc-node/register/esm-register -r dotenv/config src/main.ts dotenv_config_override=true",
    "build": "rm -rf ./dist && swc ./src --out-dir=dist && node -e '!fs.existsSync(\".sentryclirc\") || process.exit(1)' || pnpm sentry:sourcemaps",
    "build:debug": "rm -rf ./dist && swc --source-maps=true ./src --out-dir=dist && node -e '!fs.existsSync(\".sentryclirc\") || process.exit(1)' || pnpm sentry:sourcemaps",
    "type:check": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --fix --cache .",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "test": "jest",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org mmmm-q0 --project fixup-twitter-link ./dist && sentry-cli sourcemaps upload --org mmmm-q0 --project fixup-twitter-link ./dist"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e",
  "devDependencies": {
    "@eslint/js": "9.38.0",
    "@jest/globals": "29.7.0",
    "@sentry/cli": "2.57.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.43",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "0.2.39",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "22.20.1",
    "dotenv": "17.4.2",
    "dprint": "0.50.2",
    "eslint": "9.38.0",
    "eslint-config-prettier": "10.1.5",
    "globals": "16.5.0",
    "jest": "29.7.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.41.0"
  },
  "dependencies": {
    "@discordjs/collection": "2.1.1",
    "@discordjs/core": "2.5.0",
    "@discordjs/rest": "2.6.1",
    "@discordjs/ws": "2.0.4",
    "@sentry/node": "10.67.0",
    "@sentry/profiling-node": "10.67.0"
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry-internal/node-cpu-profiler",
      "@sentry/cli",
      "@sentry/profiling-node",
      "@swc/core",
      "dprint"
    ]
  }
}
